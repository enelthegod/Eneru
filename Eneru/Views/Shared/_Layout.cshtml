<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eneru</title>
</head>
<body>
    <nav style="display:flex; align-items:center; gap:2rem; padding:1rem 2rem; border-bottom:1px solid #ddd;">
        <a href="/" style="font-weight:bold; text-decoration:none; font-size:1.2rem;">Eneru</a>
        <a href="/Products">Catalog</a>

        <div style="margin-left:auto; display:flex; gap:1rem; align-items:center;">
            @if (Context.Session.GetInt32("UserId") != null)
            {
                <a href="/Cart">Cart</a>
                <span>@Context.Session.GetString("UserName")</span>
                <form method="post" action="/Account/Logout" style="display:inline;">
                    <button type="submit">Logout</button>
                </form>
            }
            else
            {
                <a href="/Account/Login">Login</a>
                <a href="/Account/Register">Register</a>
            }
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer style="text-align:center; padding:2rem; border-top:1px solid #ddd; margin-top:3rem; color:gray;">
        © 2026 - Eneru
    </footer>
</body>
</html>