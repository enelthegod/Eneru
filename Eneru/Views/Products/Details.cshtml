@model Eneru.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div style="padding:1rem;">
    <a href="/Products">← Back to catalog</a>

    <div style="display:flex; gap:2rem; margin-top:1rem;">

        <!-- Product image -->
        <div style="flex:1;">
            <img src="@Model.ImageUrl"
                 alt="@Model.Name"
                 style="width:100%; background:#f0f0f0;" />
        </div>

        <!-- Product info -->
        <div style="flex:1;">
            <p style="color:gray;">@Model.Brand</p>
            <h1>@Model.Name</h1>
            <p>@Model.Category?.Name</p>
            <h2>$@Model.Price.ToString("0.00")</h2>
            <p>@Model.Description</p>
            @if (Context.Session.GetInt32("UserId") != null)
            {
                <form method="post" action="/Cart/Add">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <input type="number" name="quantity" value="1" min="1" max="99" style="width:60px;" />
                    <button type="submit">Add to Cart</button>
                </form>
            }
            else
            {
                <a href="/Account/Login">Login to add to cart</a>
            }
        </div>

    </div>
</div>