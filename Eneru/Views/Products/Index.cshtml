@model List<Eneru.Models.Product>

@{
    ViewData["Title"] = "Catalog";
}

<div style="display:flex; gap:2rem; padding:1rem;">

    <!-- Sidebar with category filters -->
    <aside style="min-width:180px;">
        <h4>Categories</h4>
        <ul style="list-style:none; padding:0;">
            <li>
                <a href="/Products">All</a>
            </li>
            @foreach (var cat in ViewBag.Categories as List<Eneru.Models.Category>)
            {
                <li>
                    <a href="/Products?category=@cat.Slug">@cat.Name</a>
                </li>
            }
        </ul>
    </aside>

    <!-- Main content -->
    <main style="flex:1;">

        <!-- Search bar -->
        <form method="get" action="/Products" style="margin-bottom:1rem;">
            <input type="text"
                   name="search"
                   value="@ViewBag.CurrentSearch"
                   placeholder="Search products or brands..." />
            <button type="submit">Search</button>
        </form>

        <!-- Product grid -->
        <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap:1.5rem;">
            @foreach (var product in Model)
            {
                <div style="border:1px solid #ddd; padding:1rem;">
                    <img src="@product.ImageUrl"
                         alt="@product.Name"
                         style="width:100%; height:200px; object-fit:cover; background:#f0f0f0;" />
                    <p style="margin:0.5rem 0 0;">@product.Brand</p>
                    <h3 style="margin:0.25rem 0;">@product.Name</h3>
                    <p>$@product.Price.ToString("0.00")</p>
                    <a href="/Products/Details/@product.Id">View Details →</a>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <p>No products found.</p>
        }

    </main>
</div>